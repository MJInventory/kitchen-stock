{
  "name": "kitchen-inventory-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "db:migrate": "node scripts/run-postgres-migrations.mjs",
    "db:migrate:status": "node scripts/show-postgres-migrations.mjs",
    "db:index:audit": "node scripts/audit-postgres-indexes.mjs",
    "db:fk:audit": "node scripts/audit-postgres-fk-indexes.mjs",
    "db:index:expected": "node scripts/audit-postgres-expected-indexes.mjs",
    "db:baseline:audit": "node scripts/audit-postgres-baseline-drift.mjs",
    "db:check": "node scripts/check-postgres.mjs",
    "db:setup": "node scripts/setup-postgres.mjs",
    "db:import:airtable": "node scripts/import-airtable-to-postgres.mjs",
    "test:regressions": "node --test tests/*.test.mjs",
    "inspect:codebase": "node scripts/inspect-codebase.mjs",
    "inspect:changes": "node scripts/inspect-codebase.mjs --changed",
    "check:fast": "node scripts/inspect-codebase.mjs && node scripts/check-startup.mjs && node --test tests/*.test.mjs",
    "check:release": "npm run check:fast && node scripts/app-health.mjs",
    "check:startup": "node scripts/check-startup.mjs",
    "check:health": "node scripts/app-health.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "ejs": "^3.1.10",
    "nodemailer": "^6.9.16",
    "pg": "^8.16.0",
    "web-push": "^3.6.7"
  },
  "engines": {
    "node": ">=20"
  }
}
