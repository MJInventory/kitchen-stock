<!doctype html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body<% if (typeof bodyClass !== "undefined" && bodyClass) { %> class="<%= bodyClass %>"<% } %>>
    <%- typeof beforeMain !== "undefined" ? beforeMain : "" %>
    <main class="<%= typeof contentClass !== "undefined" && contentClass ? contentClass : "shell" %>">
      <header class="order-topbar<% if (typeof topbarClass !== "undefined" && topbarClass) { %> <%= topbarClass %><% } %>">
        <%- include("../partials/brand") %>
        <div class="top-actions">
          <%- typeof topbarActions !== "undefined" ? topbarActions : "" %>
        </div>
      </header>

      <% if (typeof showPageIntro !== "undefined" && showPageIntro) { %>
        <section class="page-intro">
          <p class="eyebrow"><%= typeof pageEyebrow !== "undefined" ? pageEyebrow : "" %></p>
          <h1><%= typeof pageTitle !== "undefined" ? pageTitle : "MJ Stock Magic" %></h1>
        </section>
      <% } %>

      <%- typeof body !== "undefined" ? body : "" %>
    </main>

    <footer class="app-version">Release v<%= typeof appVersion !== "undefined" ? appVersion : "" %><% if (typeof appReleaseLabel !== "undefined" && appReleaseLabel) { %> fix <%= appReleaseLabel %><% } %></footer>
    <%- include("../partials/footer-scripts") %>
  </body>
</html>
