<!doctype html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body<% if (typeof bodyClass !== "undefined" && bodyClass) { %> class="<%= bodyClass %>"<% } %>>
    <%- typeof beforeMain !== "undefined" ? beforeMain : "" %>
    <main class="<%= typeof contentClass !== "undefined" && contentClass ? contentClass : "shell" %>">
      <header class="order-topbar<% if (typeof topbarClass !== "undefined" && topbarClass) { %> <%= topbarClass %><% } %>">
        <%- include("../partials/brand") %>
        <div class="top-actions">
          <button type="button" class="install-app-button no-print" data-install-app hidden>Install app</button>
          <a id="currentUser" class="user-chip" href="/settings.html"></a>
          <%- typeof topbarActions !== "undefined" ? topbarActions : "" %>
        </div>
      </header>

      <% if (typeof showPageIntro !== "undefined" && showPageIntro) { %>
        <section class="page-intro">
          <p class="eyebrow"><%= typeof pageEyebrow !== "undefined" ? pageEyebrow : "" %></p>
          <h1><%= typeof pageTitle !== "undefined" ? pageTitle : "MJ Stock Magic" %></h1>
        </section>
      <% } %>

      <%- typeof body !== "undefined" ? body : "" %>
    </main>

    <div class="ios-install-help no-print" data-ios-install-help hidden role="dialog" aria-modal="true" aria-labelledby="ios-install-title">
      <strong id="ios-install-title">Install MJ Stock Magic</strong>
      <span>In Safari, tap the Share button, then choose <b>Add to Home Screen</b>.</span>
      <button type="button" data-install-close>Close</button>
    </div>

    <footer class="app-footer">
      <div>MJ Stock Magic v<%= typeof appVersion !== "undefined" ? appVersion : "" %><% if (typeof appReleaseLabel !== "undefined" && appReleaseLabel) { %> &middot; build <%= appReleaseLabel %><% } %></div>
      <nav class="footer-links" aria-label="Legal and support">
        <a href="/terms.html">Terms of Service</a>
        <a href="/privacy.html">Privacy Policy</a>
        <a href="/support.html">Support</a>
      </nav>
      <div>&copy; <%= new Date().getFullYear() %> Enjan Enterprises. All rights reserved. The application, branding, source code, and documentation may not be copied, redistributed, or used without written permission.</div>
    </footer>
    <%- include("../partials/footer-scripts") %>
  </body>
</html>
