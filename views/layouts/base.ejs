<!doctype html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body<% if (bodyClass) { %> class="<%= bodyClass %>"<% } %>>
    <%- beforeMain %>
    <main class="<%= contentClass %>">
      <header class="order-topbar<% if (topbarClass) { %> <%= topbarClass %><% } %>">
        <%- include("../partials/brand") %>
        <div class="top-actions">
          <%- topbarActions %>
        </div>
      </header>

      <% if (showPageIntro) { %>
        <section class="page-intro">
          <p class="eyebrow"><%= pageEyebrow %></p>
          <h1><%= pageTitle %></h1>
        </section>
      <% } %>

      <%- body %>
    </main>

    <footer class="app-version">MJ Stock Magic v<%= appVersion %></footer>
    <%- include("../partials/footer-scripts") %>
  </body>
</html>
