<section class="panel">
  <form id="invoiceForm">
    <label>
      Supplier
      <input id="supplierName" type="text" autocomplete="organization">
    </label>
    <div class="row">
      <label>
        Invoice number
        <input id="invoiceNumber" type="text">
      </label>
      <label>
        Invoice total
        <input id="invoiceTotal" type="number" min="0" step="0.01">
      </label>
    </div>
    <label>
      Photo URL
      <input id="photoUrl" type="url" placeholder="https://...">
    </label>
    <label>
      Invoice file
      <input id="invoicePhoto" type="file" accept="image/*,application/pdf,.pdf" capture="environment">
    </label>
    <div class="row">
      <label>
        OCR mode
        <select id="ocrMode">
          <option value="auto">Auto clean</option>
          <option value="contrast">High contrast</option>
          <option value="threshold">Black and white</option>
          <option value="original">Original image</option>
        </select>
      </label>
      <label>
        Rotate
        <select id="ocrRotation">
          <option value="0">No rotation</option>
          <option value="90">Rotate right</option>
          <option value="270">Rotate left</option>
          <option value="180">Upside down</option>
        </select>
      </label>
      <label>
        Text type
        <select id="ocrTextType">
          <option value="invoice">Invoice lines</option>
          <option value="dense">Small dense receipt</option>
        </select>
      </label>
    </div>
    <div class="row action-row">
      <button id="ocrButton" class="secondary" type="button">OCR File</button>
      <button id="emailInvoiceButton" class="secondary" type="button">Send to Accounting</button>
      <button id="applyLinesButton" type="button" disabled>Apply Selected Lines</button>
    </div>
    <p class="helper-text">Use a straight, bright photo that fills the frame, or a clear PDF under 1 MB. If a photo OCR result is messy, try Black and white or High contrast.</p>
    <img id="invoicePreview" class="invoice-preview" alt="" hidden>
    <canvas id="ocrCanvas" class="invoice-preview" hidden></canvas>
    <label>
      Extracted text / line notes
      <textarea id="extractedText" rows="5"></textarea>
    </label>
    <div class="row action-row">
      <button id="buildLinesButton" class="secondary" type="button">Build Lines From Text</button>
      <button id="teachHeaderButton" class="secondary" type="button">Teach Header</button>
      <button id="teachLinesButton" class="secondary" type="button">Teach Lines</button>
    </div>
    <section class="invoice-lines-section">
      <div class="section-header">
        <h2>Invoice Lines</h2>
        <span id="ocrProgress"></span>
      </div>
      <div id="invoiceLines" class="invoice-lines">
        <p class="empty-sheet">OCR a photo or PDF to build invoice lines.</p>
      </div>
    </section>
    <label>
      Notes
      <textarea id="invoiceNotes" rows="3"></textarea>
    </label>
    <button type="submit">Save Invoice Capture</button>
    <p id="invoiceMessage" role="status"></p>
  </form>
</section>
