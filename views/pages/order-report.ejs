<section class="panel no-print">
  <div class="row">
    <label>
      Report date
      <input id="reportDate" type="date">
    </label>
    <label id="guestCountField" hidden>
      Guests
      <input id="guestCountInput" type="number" min="0" step="1" placeholder="Daily guests">
    </label>
    <label id="guestNotesField" hidden>
      Guest notes
      <input id="guestNotesInput" type="text" placeholder="Optional note">
    </label>
  </div>
  <div class="sheet-actions">
    <button id="loadReportButton" type="button">Load Report</button>
    <button id="saveGuestsButton" type="button" hidden>Save Guests</button>
    <button id="printReportButton" type="button">Print / Save PDF</button>
  </div>
  <p id="reportMessage" role="status"></p>
</section>

<section class="print-sheet order-report-sheet">
  <div class="sheet-header">
    <div>
      <p class="eyebrow">Daily Order Status</p>
      <h1>Order Report</h1>
    </div>
    <div class="sheet-meta">
      <span id="printDate"></span>
    </div>
  </div>

  <div id="reportSummary" class="report-summary"></div>
  <div id="reportList" class="sheet-list"></div>
  <div class="standing-report-section">
    <div class="sheet-header standing-report-header">
      <div>
        <p class="eyebrow">Scheduled Deliveries</p>
        <h2>Standing Orders</h2>
      </div>
    </div>
    <div id="standingReportSummaryList" class="sheet-list no-print"></div>
    <div id="standingReportList" class="sheet-list print-only"></div>
  </div>
  <div class="standing-report-section">
    <div class="sheet-header standing-report-header">
      <div>
        <p class="eyebrow">Daily Changes</p>
        <h2>Adds, Changes, Deletes</h2>
      </div>
    </div>
    <div id="activitySummary" class="report-summary report-summary-compact"></div>
    <div id="activityReportList" class="sheet-list"></div>
  </div>
</section>
