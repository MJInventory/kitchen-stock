<section class="panel no-print">
  <div class="row">
    <label>
      Delivery date
      <input id="sheetDate" type="date">
    </label>
  </div>
  <div class="sheet-actions">
    <button id="loadSheetButton" type="button">Load Receiving</button>
  </div>
  <p id="sheetMessage" role="status"></p>
</section>

<section class="print-sheet">
  <div class="sheet-header">
    <div>
      <p class="eyebrow">Cargo Receiving</p>
      <h1>Receiving Sheet</h1>
    </div>
    <div class="sheet-meta">
      <span id="printDate"></span>
      <span id="printReceiver"></span>
    </div>
  </div>
  <div id="receivingList" class="sheet-list"></div>
</section>
