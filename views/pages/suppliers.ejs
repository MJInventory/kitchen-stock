<section class="panel">
  <h2>Add Supplier</h2>
  <form id="supplierForm" class="admin-form-grid">
    <label>Supplier name <input id="supplierName" type="text" required></label>
    <label>Contact information <textarea id="supplierContact" rows="3" placeholder="Phone, email, notes"></textarea></label>
    <label class="check-label"><input id="supplierActive" type="checkbox" checked> Active</label>
    <button type="submit">Add Supplier</button>
    <p id="supplierMessage" role="status"></p>
  </form>
</section>

<section id="supplierList" class="settings-list"></section>
