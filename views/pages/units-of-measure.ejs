<section class="panel">
  <h2>Add Unit</h2>
  <form id="unitForm" class="admin-form-grid">
    <label>Unit name <input id="unitName" type="text" required></label>
    <label class="check-label"><input id="unitActive" type="checkbox" checked> Active</label>
    <button type="submit">Add Unit</button>
    <p id="unitMessage" role="status"></p>
  </form>
</section>

<section id="unitList" class="settings-list"></section>
