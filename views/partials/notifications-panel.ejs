<section class="<%= typeof panelClass !== 'undefined' && panelClass ? panelClass : 'daily-order-panel notification-panel' %>">
  <div class="daily-order-heading">
    <h2>Notifications</h2>
    <span id="notificationCount"></span>
  </div>
  <div class="notification-actions">
    <button id="readAllNotificationsButton" class="icon-button" type="button"><%= typeof clearLabel !== 'undefined' && clearLabel ? clearLabel : 'Clear notifications' %></button>
    <% if (typeof showPushButton !== 'undefined' && showPushButton) { %>
      <button id="enablePushButton" class="icon-button" type="button" hidden>Enable phone notifications</button>
    <% } %>
  </div>
  <div id="notificationList" class="<%= typeof listClass !== 'undefined' && listClass ? listClass : 'notification-list' %>"></div>
</section>
